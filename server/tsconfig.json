{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "module": "ESNext",
    "types": ["node"],
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["./**/*"]
}
