{
  "name": "st-tow-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint --max-warnings=0 \"src/**/*.{ts,tsx}\"",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,md}\"",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,md}\"",
    "check:module-bindings": "node ./scripts/check-module-bindings.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.3",
    "lucide-react": "^0.488.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "spacetimedb": "^2.0.2",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@01sadra/tailwind-neobrutalism": "^0.1.0",
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "~5.6.2",
    "vite": "^7.1.5"
  }
}
